        "import hashlib\n",
        "def file_hash(filename, algo=\"sha256\"):\n",
        "    h = hashlib.new(algo)\n",
        "    with open(filename, \"rb\") as f:\n",
        "        h.update(f.read())\n",
        "    return h.hexdigest()\n",
        "with open(\"sample.txt\", \"w\") as f:\n",
        "    f.write(\"Confidential report v1\")\n",
        "print(\"Original hash :\", file_hash(\"sample.txt\"))\n",
        "with open(\"sample.txt\", \"a\") as f:\n",
        "    f.write(\" - tampered!\")\n",
